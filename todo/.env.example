# ===========================
# Database Configuration
# ===========================
# PostgreSQL database connection URL
DB_URL=jdbc:postgresql://your-host/your-database?sslmode=require&channel_binding=require

# Database username
DB_USERNAME=your_db_username

# Database password
DB_PASSWORD=your_db_password

# ===========================
# Server Configuration
# ===========================
# Port on which the Spring Boot application runs
SERVER_PORT=8001

# ===========================
# JPA/Hibernate Configuration
# ===========================
# DDL auto (create, create-drop, validate, update)
JPA_HIBERNATE_DDL_AUTO=update

# Hibernate dialect for your database
JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Show SQL statements in logs
JPA_SHOW_SQL=true

# Format SQL statements
JPA_FORMAT_SQL=true

# ===========================
# Connection Pool Configuration
# ===========================
# Maximum number of connections in the pool
DATASOURCE_HIKARI_MAX_POOL_SIZE=5

# Minimum idle connections
DATASOURCE_HIKARI_MIN_IDLE=1

# Connection timeout in milliseconds
DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000

# Idle timeout in milliseconds
DATASOURCE_HIKARI_IDLE_TIMEOUT=600000

# Maximum lifetime in milliseconds
DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# ===========================
# Logging Configuration
# ===========================
# Hibernate SQL logging level
LOGGING_LEVEL_HIBERNATE_SQL=DEBUG

# Hibernate parameter binder logging level
LOGGING_LEVEL_HIBERNATE_BINDER=TRACE

# ===========================
# CORS Configuration
# ===========================
# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173

# ===========================
# Application Configuration
# ===========================
# Application name
APP_NAME=todo-fullstack

# Environment (development, staging, production)
APP_ENV=development
