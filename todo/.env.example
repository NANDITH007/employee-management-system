APP_NAME=todo-api
SERVER_PORT=8000
DB_URL=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME?sslmode=require
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD
JPA_HIBERNATE_DDL_AUTO=update
JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
